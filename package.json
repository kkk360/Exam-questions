{
  "name": "smart-exam-system",
  "version": "1.0.1",
  "description": "智能出题系统 - 教师桌面端应用",
  "main": "./out/main/index.js",
  "author": "wangkai <wangkaicode@foxmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kkk360/Exam-questions.git"
  },
  "homepage": "https://github.com/kkk360/Exam-questions",
  "bugs": {
    "url": "https://github.com/kkk360/Exam-questions/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss,html}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,html}\"",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "electron-updater": "^6.8.9",
    "katex": "^0.16.47"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.6.1",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^3.0.0",
    "@eslint/js": "^9.39.4",
    "@types/katex": "^0.16.8",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.0",
    "antd": "^6.4.4",
    "dayjs": "^1.11.21",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^6.30.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.21",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.smartexam.app",
    "productName": "智能出题系统",
    "publish": [
      {
        "provider": "github",
        "owner": "kkk360",
        "repo": "Exam-questions"
      }
    ],
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx"
    ],
    "asar": true,
    "compression": "maximum",
    "forceCodeSigning": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null,
      "signtoolOptions": {
        "signingHashAlgorithms": []
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "智能出题系统",
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052"
    }
  }
}
